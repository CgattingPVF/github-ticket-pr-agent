APP_HOST=127.0.0.1
APP_PORT=3060
SECRET_KEY=replace-this-with-a-random-value
DATA_DIR=./data
WORKSPACE_ROOT=./workspaces

# The generated prompt is passed to each command over stdin.
AGENT_COMMAND=codex exec --sandbox workspace-write --ask-for-approval never -
REVIEW_COMMAND=codex exec --sandbox workspace-write --ask-for-approval never -
CLAUDE_COMMAND=claude -p
EDITOR_COMMAND=code --reuse-window

COMMAND_TIMEOUT_SECONDS=3600
MINIMUM_CONFIDENCE=0.90
MAX_REPAIR_CYCLES=1
CLOSE_ISSUE_ON_MERGE=false

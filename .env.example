APP_HOST=127.0.0.1
APP_PORT=3060
SECRET_KEY=replace-this-with-a-random-value
DATA_DIR=./data
WORKSPACE_ROOT=./workspaces

# GitHub OAuth (optional: if set, enables "Login with GitHub" button)
# Create an OAuth app at https://github.com/settings/developers
GITHUB_CLIENT_ID=your-client-id-here
GITHUB_CLIENT_SECRET=your-client-secret-here

# The generated prompt is passed to each command over stdin.
AGENT_COMMAND=codex exec --sandbox workspace-write -
REVIEW_COMMAND=codex exec --sandbox workspace-write -
CLAUDE_COMMAND=claude -p --output-format stream-json --verbose --dangerously-skip-permissions
EDITOR_COMMAND=code --new-window

COMMAND_TIMEOUT_SECONDS=3600
MINIMUM_CONFIDENCE=0.90
MAX_REPAIR_CYCLES=1
CLOSE_ISSUE_ON_MERGE=false

# Optional: path to a local repository to use instead of cloning from GitHub
# LOCAL_REPO_PATH=/home/claytongatting/CRM_APP_PVF
